# Backend
HOST=127.0.0.1
PORT=8787
SEED_DEMO_DATA=false
APP_TIMEZONE=Asia/Kolkata
ESCALATION_MINUTES=15
SESSION_TTL_MS=604800000
API_TIMEOUT_MS=12000
DB_PATH=./server/data/medassist.sqlite

# Twilio
# SMS reminders can use either a Messaging Service SID or a sender number.
# Voice escalation calls still require a Twilio phone number.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_SMS_FROM=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_VERIFY_SERVICE_SID=
# Use your public TwiML URL. For testing you can keep Twilio demo URL.
TWILIO_TWIML_URL=http://demo.twilio.com/docs/voice.xml

# Optional live health news API
NEWS_API_KEY=pub_46129761223140cebd4b657e0d60ed41
